  }

  // line 2
  subgraph cluster2 { style=invis;
    l2c0 [label="Organism (COB)", style="filled,rounded", shape="parallelogram", fillcolor="darkseagreen1", fixedsize=true, width=2, height=1];
    l2c1 [style=invis, shape=point, fixedsize=true, width=0, height=0];
    l2c2 [label="disease \n (DO)", style="filled,rounded", shape="parallelogram", fillcolor="grey90", fixedsize=true, width=2, height=1];
    l2c3 [style=invis, shape=point, fixedsize=true, width=0, height=0];
    l2c4 [label="anatomical \n structure \n (UBERON)", style="filled,rounded", shape="parallelogram", fillcolor="darkseagreen1", fixedsize=true, width=2, height=1];
