digraph OBI_Mass_Measurement {
  // Global graph settings
  bgcolor="white";
  label="";
  fontcolor="black";
  rankdir="LR";
  nodesep=0.25;
  ranksep=0.35;

  fontname="Helvetica,Arial,sans-serif";
  node [fontname="Helvetica,Arial,sans-serif"];
  edge [fontname="Helvetica,Arial,sans-serif"];

  // Row anchors to keep columns aligned
  { rank=same;
    line00 [style=invis, shape=point, fixedsize=true, width=0, height=0.5];
    line0  [style=invis, shape=point, fixedsize=true, width=0, height=0.5];
    line1  [style=invis, shape=point, fixedsize=true, width=0, height=0.5];
    line2  [style=invis, shape=point, fixedsize=true, width=0, height=0.5];
    line3  [style=invis, shape=point, fixedsize=true, width=0, height=0.5];
    line4  [style=invis, shape=point, fixedsize=true, width=0, height=0.5];
    line5  [style=invis, shape=point, fixedsize=true, width=0, height=0.5];
    line6  [style=invis, shape=point, fixedsize=true, width=0, height=0.5];

    line00 -> line0  [style=invis];
    line0  -> line1  [style=invis];
    line1  -> line2  [style=invis];
    line2  -> line3  [style=invis];
    line3  -> line4  [style=invis];
    line4  -> line5  [style=invis];
    line5  -> line6  [style=invis];
  }

  // line 00
  subgraph cluster00 { style=invis;
    l00c0 [label="independent \n continuant \n (BFO)", style="filled,rounded", shape=box, fixedsize=true, width=2, height=1, fillcolor="white"];
    l00c1 [label="process \n (BFO)", style="filled,rounded", shape=box, fixedsize=true, width=2, height=1, fillcolor="white"];
    l00c2 [label="specifically \n dependent \n continuant \n (BFO)", style="filled,rounded", shape=box, fixedsize=true, width=2, height=1, fillcolor="white"];
    l00c3 [label="independent \n continuant \n (BFO)", style="filled,rounded", shape=box, fixedsize=true, width=2, height=1, fillcolor="white"];
    l00c4 [label="independent \n continuant \n (BFO)", style="filled,rounded", shape=box, fixedsize=true, width=2, height=1, fillcolor="white"];
    l00c5 [label="process \n (BFO)", style="filled,rounded", shape=box, fixedsize=true, width=2, height=1, fillcolor="white"];
    l00c6 [label="generically \n dependent \n continuant \n (BFO)", style="filled,rounded", shape=box, fixedsize=true, width=2, height=1, fillcolor="white"];
#    l00c7 [label="specifically \n dependent \n continuant \n (BFO)", style="filled,rounded", shape=box, fixedsize=true, width=2, height=1, fillcolor="white"];
    // l00c8 was commented in your original

    l00c0 -> l00c1 [style=invis];
    l00c1 -> l00c2 [style=invis];
    l00c2 -> l00c3 [style=invis];
    l00c3 -> l00c4 [style=invis];
    l00c4 -> l00c5 [style=invis];
    l00c5 -> l00c6 [style=invis];
#    l00c6 -> l00c7 [style=invis];
  }

  // line 0
  subgraph cluster0 { style=invis;
    l0c0 [label="material \n entity (BFO)", style="filled,rounded", shape="parallelogram", fillcolor="darkseagreen1", fixedsize=true, width=2, height=1];
    l0c1 [style=invis, shape=point, fixedsize=true, width=0, height=0];
    l0c2 [label="realizable  \n entity (BFO)", style="filled,rounded", shape="parallelogram", fillcolor="grey90", fixedsize=true, width=2, height=1];
    l0c3 [label="material \n entity (BFO)", style="filled,rounded", shape="parallelogram", fillcolor="darkseagreen1", fixedsize=true, width=2, height=1];
    l0c4 [label="material \n entity (BFO)", style="filled,rounded", shape="parallelogram", fillcolor="darkseagreen1", fixedsize=true, width=2, height=1];
    l0c5 [label="planned \n process (OBI)", style="filled,rounded", shape="parallelogram", fixedsize=true, width=2, height=1, fillcolor="lightblue2"];
    l0c6 [label="information \n content \n entity (IAO)", style="filled,rounded", shape="parallelogram", fixedsize=true, width=2, height=1, fillcolor="grey90"];
#    l0c7 [label="quality (BFO)", style="filled,rounded", shape="parallelogram", fillcolor="lightyellow", fixedsize=true, width=2, height=1];

    l0c0 -> l0c1 [style=invis];
    l0c1 -> l0c2 [style=invis];
    l0c2 -> l0c3 [style=invis];
    l0c3 -> l0c4 [style=invis];
    l0c4 -> l0c5 [style=invis];
    l0c5 -> l0c6 [style=invis];
#    l0c6 -> l0c7 [style=invis];
  }

  // line 1
  subgraph cluster1 { style=invis;
    l1c0 [label="material \n anatomical entity \n (UBERON)", fillcolor="darkseagreen1", style="filled,rounded", shape="parallelogram", fixedsize=true, width=2, height=1];
    l1c1 [style=invis, shape=point, fixedsize=true, width=0, height=0];
    l1c2 [label="disposition \n (BFO)", fillcolor="grey90", style="filled,rounded", shape="parallelogram", fixedsize=true, width=2, height=1];
    l1c3 [label="material \n anatomical entity \n (UBERON)", fillcolor="darkseagreen1", style="filled,rounded", shape="parallelogram", fixedsize=true, width=2, height=1];
    l1c4 [label="material \n anatomical entity \n (UBERON)", fillcolor="darkseagreen1", style="filled,rounded", shape="parallelogram", fixedsize=true, width=2, height=1];
    l1c5 [label="assay (OBI)", fillcolor="lightblue2", style="filled,rounded", shape="parallelogram", fixedsize=true, width=2, height=1];
    l1c6 [style=invis, shape=point, fixedsize=true, width=0, height=0];
#    l1c7 [style=invis, shape=point, fixedsize=true, width=0, height=0];

    l1c0 -> l1c1 [style=invis];
    l1c1 -> l1c2 [style=invis];
    l1c2 -> l1c3 [style=invis];
    l1c3 -> l1c4 [style=invis];
    l1c4 -> l1c5 [style=invis];
    l1c5 -> l1c6 [style=invis];
