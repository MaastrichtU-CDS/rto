    l4c0 -> l4c1 [style=invis];
    l4c1 -> l4c2 [style=invis];
    l4c2 -> l4c3 [style=invis];
    l4c3 -> l4c4 [style=invis];
    l4c4 -> l4c5 [style=invis];
    l4c5 -> l4c6 [style=invis];
#    l4c6 -> l4c7 [style=invis];
  }

  // line 5
  subgraph cluster5 { style=invis;
    l5c0 [label="Homo Sapiens \n (NCBITaxon)", style="filled,rounded", shape="parallelogram", fillcolor="darkseagreen1", fixedsize=true, width=2, height=1];
    l5c1 [label="disease \n course (OGMS)", style="filled,rounded", shape="parallelogram", fixedsize=true, width=2, height=1, fillcolor="lightblue2"];
    l5c2 [label="prostate \n adenocarcinoma \n (DO)", fillcolor="grey90", style="filled,rounded", shape="parallelogram", fixedsize=true, width=2, height=1];
    l5c3 [label="lesion \n (GSSO)", fillcolor="darkseagreen1", style="filled,rounded", shape="parallelogram", fixedsize=true, width=2, height=1];
    l5c4 [label="prostate \n gland \n (UBERON)", fillcolor="darkseagreen1", style="filled,rounded", shape="parallelogram", fixedsize=true, width=2, height=1];
