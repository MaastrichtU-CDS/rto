    l2c0 -> l2c1 [style=invis];
    l2c1 -> l2c2 [style=invis];
    l2c2 -> l2c3 [style=invis];
    l2c3 -> l2c4 [style=invis];
    l2c4 -> l2c5 [style=invis];
    l2c5 -> l2c6 [style=invis];
#    l2c6 -> l2c7 [style=invis];
  }

  // line 3
  subgraph cluster3 { style=invis;
    l3c0 [style=invis, shape=point, fixedsize=true, width=0, height=0];
    l3c1 [style=invis, shape=point, fixedsize=true, width=0, height=0];
    l3c2 [label="cancer \n (DO)", style="filled,rounded", shape="parallelogram", fillcolor="grey90", fixedsize=true, width=2, height=1];
    l3c3 [style=invis, shape=point, fixedsize=true, width=0, height=0];
    l3c4 [label="organ \n (UBERON)", fillcolor="darkseagreen1", style="filled,rounded", shape="parallelogram", fixedsize=true, width=2, height=1];
    l3c5 [style=invis, shape=point, fixedsize=true, width=0, height=0];
    l3c6 [style=invis, shape=point, fixedsize=true, width=0, height=0];
#    l3c7 [style=invis, shape=point, fixedsize=true, width=0, height=0];

    l3c0 -> l3c1 [style=invis];
    l3c1 -> l3c2 [style=invis];
    l3c2 -> l3c3 [style=invis];
    l3c3 -> l3c4 [style=invis];
    l3c4 -> l3c5 [style=invis];
    l3c5 -> l3c6 [style=invis];
#    l3c6 -> l3c7 [style=invis];
  }

  // line 4
  subgraph cluster4 { style=invis;
    l4c0 [style=invis, shape=point, fixedsize=true, width=0, height=0];
    l4c1 [style=invis, shape=point, fixedsize=true, width=0, height=0];
    l4c2 [label="prostate \n cancer \n (DO)", fillcolor="grey90", style="filled,rounded", shape="parallelogram", fixedsize=true, width=2, height=1];
    l4c3 [style=invis, shape=point, fixedsize=true, width=0, height=0, label=""];
    l4c4 [style=invis, shape=point, fixedsize=true, width=0, height=0];
    l4c5 [style=invis, shape=point, fixedsize=true, width=0, height=0];
    l4c6 [style=invis, shape=point, fixedsize=true, width=0, height=0];
