    l5c6 [label="data \n item (IAO)", fillcolor="grey90", style="filled,rounded", shape="parallelogram", fixedsize=true, width=2, height=1];
#    l5c7 [label="morphology\n (PATO)", fillcolor="lightyellow", style="filled,rounded", shape="parallelogram", fixedsize=true, width=2, height=1];

    l5c0 -> l5c1 [style=invis];
    l5c1 -> l5c2 [style=invis];
    l5c2 -> l5c3 [style=invis];
    l5c3 -> l5c4 [style=invis];
    l5c4 -> l5c5 [style=invis];
    l5c5 -> l5c6 [style=invis];
#    l5c6 -> l5c7 [style=invis];
  }

  // line 6 (ABox)
  subgraph cluster6 { style=filled; label=""; bgcolor="grey95";
    l6c0 [style="filled,rounded,dashed", shape="parallelogram", fillcolor="darkseagreen1", fixedsize=true, width=2, height=1, label="◆ John", fontcolor="darkred"];
    l6c1 [fillcolor="lightblue2", style="filled,rounded", shape="parallelogram", fixedsize=true, width=2, height=1, label=" ◆ John's \n prostate cancer \n disease course", fontcolor="darkred"];
    l6c2 [fillcolor="grey90", style="filled,rounded", shape="parallelogram", fixedsize=true, width=2, height=1, label=" ◆ John's \n prostate cancer", fontcolor="darkred"];
    l6c3 [fillcolor="darkseagreen1", style="filled,rounded,dashed", shape="parallelogram", fixedsize=true, width=2, height=1, label="◆ John's \n prostate gland", fontcolor="darkred"];
    // l6c4 was commented
    l6c5 [label="◆ John's \n tumor mass \n in spine", style="filled,rounded,dashed", shape="parallelogram", fillcolor="darkseagreen1", fixedsize=true, width=2, height=1, fontcolor="darkred"];
    l6c6 [label="◆ John's \n cancer \n histological \n assay", style="filled,rounded,dashed", shape="parallelogram", fillcolor="lightblue2", fixedsize=true, width=2, height=1, fontcolor="darkred"];
    l6c7 [label="◆ John's \n adenocarcinoma \n diagnosis \n in EHR", style="filled,rounded,dashed", shape="parallelogram", fillcolor="grey90", fixedsize=true, width=2, height=1, fontcolor="darkred"];
#    l6c8 [label="◆ John's \n cancer \n morphology", style="filled,rounded,dashed", shape="parallelogram", fillcolor="lightyellow", fixedsize=true, width=2, height=1, fontcolor="darkred"];
    l6c9 [fillcolor="darkseagreen1", style="filled,rounded,dashed", shape="parallelogram", fixedsize=true, width=2, height=1, label="◆ John's \n spine", fontcolor="darkred"];

    // invisible layout chain
    l6c0 -> l6c1 [style=invis];
    l6c1 -> l6c2 [style=invis];
    l6c2 -> l6c3 [style=invis];
    l6c5 -> l6c3 [style=invis];
    l6c3 -> l6c6 [style=invis];
    l6c6 -> l6c7 [style=invis];
    l6c7 -> l6c9 [style=invis];
#    l6c8 -> l6c9 [style=invis];

    // semantic edges
    l6c0 -> l6c1 [dir=back, label=<<i><b>occurs in</b></i>>, fontcolor="dodgerblue3", color="dodgerblue3", penwidth=2];
    l6c1 -> l6c2 [label=<<i><b>realizes</b></i>>, fontcolor="dodgerblue3", color="dodgerblue3", penwidth=2];
    l6c2 -> l6c5 [dir=back, label=<<i><b>has characteristic</b></i>>, fontcolor="dodgerblue3", color="dodgerblue3", penwidth=2];
    l6c0 -> l6c3 [label=<<i><b>has part</b></i>>, fontcolor="dodgerblue3", color="dodgerblue3", penwidth=2];
    l6c5 -> l6c3 [label=<<i><b>derives from</b></i>>, fontcolor="dodgerblue3", color="dodgerblue3", penwidth=2];
    l6c5 -> l6c6 [dir=back, label=<<i><b>has specified<br/>input</b></i>>, fontcolor="dodgerblue3", color="dodgerblue3", penwidth=2];
    l6c6 -> l6c7 [label=<<i><b>has specified<br/>output</b></i>>, fontcolor="dodgerblue3", color="dodgerblue3", penwidth=2];
    l6c7 -> l6c2 [label=<<i><b>is<br/>evidence<br/>for</b></i>>, fontcolor="dodgerblue3", color="dodgerblue3", penwidth=2];
    l6c0 -> l6c2 [label=<<i><b>has characteristic</b></i>>, fontcolor="dodgerblue3", color="dodgerblue3", penwidth=2];
#    l6c5 -> l6c8 [label=<<i><b>has<br/>quality</b></i>>, fontcolor="dodgerblue3", color="dodgerblue3", penwidth=2];
    l6c0 -> l6c9 [label=<<i><b>has part</b></i>>, fontcolor="dodgerblue3", color="dodgerblue3", penwidth=2];
    l6c5 -> l6c9 [label=<<i><b>located in</b></i>>, fontcolor="dodgerblue3", color="dodgerblue3", penwidth=2];
  }

  // Attach rows to the first column’s first node per row
  line00 -> l00c0 [style=invis];
  line0  -> l0c0  [style=invis];
  line1  -> l1c0  [style=invis];
  line2  -> l2c0  [style=invis];
  line3  -> l3c0  [style=invis];
  line4  -> l4c0  [style=invis];
  line5  -> l5c0  [style=invis];
  line6  -> l6c0  [style=invis];

  // column 0 (patient)
  l00c0 -> l0c0 [dir=back, constraint=false, style=solid,  color="dodgerblue3", penwidth=4];
  l0c0  -> l1c0 [dir=back, constraint=false, style=solid,  color="dodgerblue3", penwidth=4];
  l1c0  -> l2c0 [dir=back, constraint=false, style=solid,  color="dodgerblue3", penwidth=4];
  l2c0  -> l3c0 [dir=back, constraint=false, style=dashed, color="dodgerblue3", penwidth=4];
  l3c0  -> l4c0 [constraint=false, arrowhead=none, style=dashed, color="dodgerblue3", penwidth=4];
  l4c0  -> l5c0 [constraint=false, arrowhead=none, style=dashed, color="dodgerblue3", penwidth=4];
  l5c0  -> l6c0 [dir=back, constraint=false, style=dotted, color="dodgerblue3", penwidth=4];

  // column 1 (disease course)
  l00c1 -> l0c1 [dir=back, constraint=false, style=solid, color="dodgerblue3", penwidth=4];
  l0c1  -> l1c1 [constraint=false, arrowhead=none, style=solid, color="dodgerblue3", penwidth=4];
  l1c1  -> l2c1 [constraint=false, arrowhead=none, style=solid, color="dodgerblue3", penwidth=4];
