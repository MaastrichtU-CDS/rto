  l1c3  -> l2c3 [dir=back, constraint=false, style=solid, color="dodgerblue3", penwidth=4];
  l2c3  -> l3c3 [arrowhead=none, style=solid, constraint=false, color="dodgerblue3", penwidth=4];
  l3c3  -> l4c3 [arrowhead=none, style=solid, constraint=false, color="dodgerblue3", penwidth=4];
  l4c3  -> l5c3 [arrowhead=none, style=solid, constraint=false, color="dodgerblue3", penwidth=4];
  l5c3  -> l6c5 [dir=back, constraint=false, style=dotted, color="dodgerblue3", penwidth=4];

  // column 4 (prostate gland)
  l00c4 -> l0c4 [dir=back, constraint=false, style=solid, color="dodgerblue3", penwidth=4];
  l0c4  -> l1c4 [dir=back, constraint=false, style=solid, color="dodgerblue3", penwidth=4];
  l1c4  -> l2c4 [constraint=false, arrowhead=none, style=solid, color="dodgerblue3", penwidth=4];
  l2c4  -> l3c4 [constraint=false, arrowhead=none, style=solid, color="dodgerblue3", penwidth=4];
  l3c4  -> l4c4 [constraint=false, arrowhead=none, style=solid, color="dodgerblue3", penwidth=4];
  l4c4  -> l5c4 [constraint=false, arrowhead=none, style=solid, color="dodgerblue3", penwidth=4];
  l5c4  -> l6c3 [dir=back, constraint=false, style=dotted, color="dodgerblue3", penwidth=4];

  // column 5 (histology assay)
  l00c5 -> l0c5 [dir=back, constraint=false, style=solid, color="dodgerblue3", penwidth=4];
  l0c5  -> l1c5 [dir=back, constraint=false, style=solid, color="dodgerblue3", penwidth=4];
  l1c5  -> l2c5 [dir=back, constraint=false, style=solid, color="dodgerblue3", penwidth=4];
  l2c5  -> l3c5 [arrowhead=none, style=solid, constraint=false, color="dodgerblue3", penwidth=4];
  l3c5  -> l4c5 [arrowhead=none, style=solid, constraint=false, color="dodgerblue3", penwidth=4];
  l4c5  -> l5c5 [arrowhead=none, style=solid, constraint=false, color="dodgerblue3", penwidth=4];
  l5c5  -> l6c6 [dir=back, constraint=false, style=dotted, color="dodgerblue3", penwidth=4];

  // column 6 (histology in EHR)
  l00c6 -> l0c6 [dir=back, constraint=false, style=solid, color="dodgerblue3", penwidth=4];
  l0c6  -> l1c6 [dir=back, constraint=false, style=solid, color="dodgerblue3", penwidth=4];
  l1c6  -> l2c6 [arrowhead=none, constraint=false, style=solid, color="dodgerblue3", penwidth=4];
  l2c6  -> l3c6 [arrowhead=none, constraint=false, style=solid, color="dodgerblue3", penwidth=4];
  l3c6  -> l4c6 [arrowhead=none, style=solid, constraint=false, color="dodgerblue3", penwidth=4];
  l4c6  -> l5c6 [constraint=false, arrowhead=none, style=solid, color="dodgerblue3", penwidth=4];
  l5c6  -> l6c7 [dir=back, constraint=false, style=dotted, color="dodgerblue3", penwidth=4];

  // column 7 (morphology)
#  l00c7 -> l0c7 [dir=back, constraint=false, style=solid, color="dodgerblue3", penwidth=4];
#  l0c7  -> l1c7 [dir=back, constraint=false, style=solid, color="dodgerblue3", penwidth=4];
#  l1c7  -> l2c7 [arrowhead=none, style=solid, constraint=false, color="dodgerblue3", penwidth=4];
